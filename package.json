{
  "name": "mrdiy-lbdc",
  "productName": "Mr. DIY - LOCAL",
  "version": "1.0.0",
  "description": "Biometrics Data Consolidator",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "build:client": "cd ./client && npm run build",
    "build:server": "cmd /c \"cd server && .venv\\Scripts\\python.exe -m PyInstaller --onefile --hidden-import=uvicorn.logging --hidden-import=uvicorn.loops --hidden-import=uvicorn.loops.auto --hidden-import=uvicorn.protocols --hidden-import=uvicorn.protocols.http --hidden-import=uvicorn.protocols.http.auto --hidden-import=uvicorn.protocols.websockets --hidden-import=uvicorn.protocols.websockets.auto --hidden-import=uvicorn.lifespan --hidden-import=uvicorn.lifespan.on --name lbdc_server app\\main.py && copy .env dist\\.env\"",
    "install:client": "cd ./client && npm install",
    "install:server": "cmd /c \"cd server && .venv\\Scripts\\pip.exe install -r requirements.txt\"",
    "package": "npm run build:client && electron-forge package",
    "make": "npm run install:client && npm run build:client && npm run install:server && npm run build:server && electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "preview": "vite preview"
  },
  "keywords": [],
  "author": {
    "name": "Mayan Solutions Inc.",
    "email": "johnkurt@mayan.com.ph"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/express": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "electron": "41.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "typescript": "~4.5.4",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "express": "^5.2.1",
    "serve": "^14.2.6"
  }
}
