{
  "name": "mrdiy-lbdc",
  "productName": "Mr. DIY - LOCAL",
  "version": "2.2.7",
  "description": "Biometrics Data Consolidator",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "install:client": "cd ./client && npm install",
    "install:server": "tsx scripts/install-server.ts",
    "install:all": "npm run install:client && npm run install:server",
    "build:client": "cd ./client && npm run build",
    "build:server": "tsx scripts/build-server.ts",
    "build:all": "npm run build:client && npm run build:server",
    "publish": "electron-builder --publish always",
    "lint": "eslint --ext .ts,.tsx .",
    "preview": "vite preview",
    "build": "npm run build:all && electron-builder"
  },
  "keywords": [],
  "author": {
    "name": "Mayan Solutions Inc.",
    "email": "johnkurt@mayan.com.ph"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@types/express": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "electron": "41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "tsx": "^4.21.0",
    "typescript": "~4.5.4",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "serve": "^14.2.6"
  }
}
